{
    "name": "ai-code-reviewer-js",
    "displayName": "AI Code Reviewer",
    "description": "Reviews the currently opened code file using an AI API and provides suggestions.",
    "version": "0.0.1",
    "publisher": "ai-reviewer-dev",
    "icon": "media/robot.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/example/ai-reviewer"
    },
    "license": "MIT",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "*"
    ],
    "main": "./src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "aiCodeReviewer.reviewCode",
                "title": "AI: Review Current File"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "ai-code-reviewer-sidebar",
                    "title": "AI Code Reviewer",
                    "icon": "media/robot.svg"
                }
            ]
        },
        "views": {
            "ai-code-reviewer-sidebar": [
                {
                    "type": "webview",
                    "id": "aiCodeReviewer.sidebar",
                    "name": "AI Code Reviewer"
                }
            ]
        },
        "configuration": {
            "title": "AI Code Reviewer",
            "properties": {
                "aiCodeReviewer.apiKey": {
                    "type": "string",
                    "default": "",
                    "description": "API Key for the AI endpoint. For Gemini, get your key from https://aistudio.google.com/app/apikey"
                },
                "aiCodeReviewer.apiEndpoint": {
                    "type": "string",
                    "default": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
                    "description": "Google Gemini API Endpoint URL."
                }
            }
        }
    },
    "scripts": {
        "test": "node ./src/test/runTest.js",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.6",
        "@types/node": "18.x",
        "@types/vscode": "^1.80.0",
        "@vscode/test-electron": "^2.3.8",
        "@vscode/vsce": "^2.19.0",
        "eslint": "^8.41.0",
        "glob": "^13.0.6",
        "mocha": "^10.2.0"
    },
    "dependencies": {
        "@google/genai": "^1.45.0",
        "axios": "^1.4.0"
    }
}
